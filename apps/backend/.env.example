DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ahorrando
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-super-secret-jwt-key
ENCRYPTION_KEY=your-fernet-key-base64

# Entorno: "development" o "production"
# En development, CORS permite localhost:3000 si no se especifica ALLOWED_ORIGINS
ENV=development

# REQUERIDO EN PRODUCCIÓN — orígenes permitidos separados por coma
# El proceso aborta si ENV=production y esta variable no está seteada
ALLOWED_ORIGINS=https://ahorrandoando.app,https://www.ahorrandoando.app

# Opcional — para wallets on-chain (Etherscan API, gratuita en etherscan.io)
ETHERSCAN_API_KEY=

# Opcional — Sentry (dejar vacío para desactivar)
SENTRY_DSN=

# Opcional — Email de alertas via Resend (resend.com, tier free)
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=alertas@ahorrandoando.app

# Opcional — Web Push (generar con: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key, v.public_key)")
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_EMAIL=mailto:admin@ahorrandoando.app

# REQUERIDO para "Continuar con Google" — credenciales OAuth 2.0
# Crear en https://console.cloud.google.com/apis/credentials
#   Tipo: "ID de cliente OAuth" → "Aplicación web"
#   Origen autorizado:       http://localhost:3000  (en prod, el dominio real)
#   URI de redirección:      http://localhost:8000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# URL del frontend (para los redirects de OAuth y links en emails)
FRONTEND_URL=http://localhost:3000

# REQUERIDO para verificación de email y reset de contraseña por SMTP.
# Sin esto los códigos NO se envían (en desarrollo aparecen en los logs del backend).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
