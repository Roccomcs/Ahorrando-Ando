DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ahorrando
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-super-secret-jwt-key
ENCRYPTION_KEY=your-fernet-key-base64

# Entorno: "development" o "production"
# En development, CORS permite localhost:3000 si no se especifica ALLOWED_ORIGINS
ENV=development

# REQUERIDO EN PRODUCCIÓN — orígenes permitidos separados por coma
# El proceso aborta si ENV=production y esta variable no está seteada
ALLOWED_ORIGINS=https://ahorrandoando.app,https://www.ahorrandoando.app

# Opcional — para wallets on-chain (Etherscan API, gratuita en etherscan.io)
ETHERSCAN_API_KEY=

# Opcional — Sentry (dejar vacío para desactivar)
SENTRY_DSN=

# Opcional — Email de alertas via Resend (resend.com, tier free)
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=alertas@ahorrandoando.app

# Opcional — Web Push (generar con: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key, v.public_key)")
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_EMAIL=mailto:admin@ahorrandoando.app
